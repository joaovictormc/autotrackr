# =============================================
# AutoTrackr — Environment Variables Template
# Copy this file to .env and fill in the values
# =============================================

# --- Backend ---
# For local dev with Docker:
# DATABASE_URL="postgresql://autotrackr:localdev@localhost:5432/autotrackr"
# For staging (ZimaOS via Tailscale):
DATABASE_URL="postgresql://<usuario>:<senha>@<ip-tailscale>:5432/<nome-do-banco>"

JWT_SECRET="minimo-32-caracteres-substitua-em-producao"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

FRONTEND_URL="http://localhost:5173"
PORT=3000

# Email (para reset de senha)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@autotrackr.com"

# --- Frontend ---
VITE_API_URL="http://localhost:3000/api/v1"
